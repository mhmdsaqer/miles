# Server
PORT=3000
NODE_ENV=development

# Database (Atlas) - Replace with your actual URI in production
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/miles_beauty_store?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=24h

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Cloudinary (for image uploads in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin defaults (for first setup only - change in production)
DEFAULT_ADMIN_EMAIL=admin@miles.ps
DEFAULT_ADMIN_PASSWORD=change_this_in_production
